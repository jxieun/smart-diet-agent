// 설정 및 공통 Enum

// prisma/schema/base.prisma

generator client {
  provider        = "prisma-client-js"
  // 스키마 폴더 기능을 사용하기 위해 previewFeatures 추가
  previewFeatures = ["driverAdapters", "prismaSchemaFolder"]
}

datasource db {
  provider = "postgresql"
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

// Meal 모델

// prisma/schema/meal.prisma

model Meal {
  id       String   @id @default(uuid())
  title    String
  mealType MealType @default(BREAKFAST)
  calories Float
  carbs    Float?
  protein  Float?
  fat      Float?
  mealDate DateTime @default(now())

  // User 모델과의 관계
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([mealDate])
  @@map("meals")
}

// User 모델

// prisma/schema/user.prisma

model User {
  id             String  @id @default(uuid())
  email          String  @unique
  password       String
  nickname       String
  activityLevel  String? @map("activity_level")
  goalCalories   Int     @default(2000) @map("goal_calories")
  willpowerScore Int     @default(100) @map("willpower_score")

  // Meal 모델과의 관계
  meals Meal[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}
